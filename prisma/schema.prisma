generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobLabel {
  APPLY
  MAYBE
  SKIP
}

enum JobStatus {
  SOURCED
  PARSED
  SCORED
  SHORTLISTED
  MATERIALS_READY
  APPLIED
  INTERVIEW
  REJECTED
}

model UserProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fullName  String?
  headline  String?
  location  String?
  languages Json?

  preferences CandidatePreferences?
}

model CandidatePreferences {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userProfileId String @unique
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  targetTitles     Json?
  positiveKeywords Json?
  negativeKeywords Json?

  minNetEurPerMonth Int?
  preferredCountries Json?
  preferredCities    Json?
  preferredWorkMode  String?
  targetSeniority    String?
}

model JobPosting {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  source      String?
  sourceUrl   String   @unique
  companyName String?
  title       String?
  location    String?
  workMode    String?
  language    String?

  salaryText  String?
  salaryMinEur Int?
  salaryMaxEur Int?
  currency    String?

  postedAt    DateTime?
  scrapedAt   DateTime?

  rawHtml     String?
  rawText     String?
  parsedJson  Json?

  status      JobStatus @default(SOURCED)

  evaluations JobEvaluation[]
  applications Application[]
}

model JobEvaluation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  jobPostingId String
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  label       JobLabel
  totalScore  Int

  seniorityFit   Int
  stackFit       Int
  domainFit      Int
  languageFit    Int
  geographyFit   Int
  salaryFit      Int
  screeningFit   Int
  honestyFit     Int
  effortReward   Int
  strategicValue Int

  reasons Json?
  risks   Json?
  gaps    Json?
  narrativeSuggestion String?

  llmModel String?
  llmPromptVersion String?
}

model Application {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobPostingId String
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  status     String
  appliedAt  DateTime?
  notes      String?

  materials  ApplicationMaterial[]
}

model ApplicationMaterial {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  type     String
  content  String?
  version  Int @default(1)
}

model AutomationRun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type      String
  status    String
  startedAt DateTime?
  endedAt   DateTime?

  logs AutomationLog[]
}

model AutomationLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  runId String
  run   AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  level   String
  message String
  data    Json?
}
