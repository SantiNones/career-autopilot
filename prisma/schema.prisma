generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobLabel {
  APPLY
  MAYBE
  SKIP
}

enum ApplicationStatus {
  DISCOVERED
  APPLY
  MAYBE
  SKIP
  APPLIED
  INTERVIEW
  REJECTED
  OFFER
}

enum JobStatus {
  SOURCED
  PARSED
  SCORED
  SHORTLISTED
  MATERIALS_READY
  APPLIED
  INTERVIEW
  REJECTED
}

model UserProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fullName     String?
  headline     String?
  location     String?
  phone        String?
  email        String?
  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?
  languages    Json?

  preferences CandidatePreferences?
}

model CandidatePreferences {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userProfileId String @unique
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  targetTitles     Json?
  positiveKeywords Json?
  negativeKeywords Json?

  minNetEurPerMonth Int?
  preferredCountries Json?
  preferredCities    Json?
  preferredWorkMode  String?
  targetSeniority    String?
}

model JobPosting {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  source      String?
  sourceUrl   String   @unique
  companyName String?
  title       String?
  location    String?
  workMode    String?
  language    String?

  salaryText  String?
  salaryMinEur Int?
  salaryMaxEur Int?
  currency    String?

  postedAt    DateTime?
  scrapedAt   DateTime?

  rawHtml     String?
  rawText     String?
  parsedJson  Json?

  status            JobStatus         @default(SOURCED)
  applicationStatus ApplicationStatus @default(DISCOVERED)

  evaluations  JobEvaluation[]
  applications Application[]
  materials    JobMaterial[]
  fitAnalysis  FitAnalysis?
  positioningProfile PositioningProfile?
}

model JobEvaluation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  jobPostingId String
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  label       JobLabel
  totalScore  Int

  seniorityFit   Int
  stackFit       Int
  domainFit      Int
  languageFit    Int
  geographyFit   Int
  salaryFit      Int
  screeningFit   Int
  honestyFit     Int
  effortReward   Int
  strategicValue Int

  reasons Json?
  risks   Json?
  gaps    Json?
  narrativeSuggestion String?

  llmModel String?
  llmPromptVersion String?
}

model Application {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobPostingId String
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  status     String
  appliedAt  DateTime?
  notes      String?

  materials  ApplicationMaterial[]
}

model ApplicationMaterial {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  type     String
  content  String?
  version  Int @default(1)
}

enum MaterialType {
  TAILORED_CV
  COVER_LETTER
  RECRUITER_MESSAGE
  SCREENING_ANSWERS
}

enum MaterialStatus {
  DRAFT
  REVIEWED
}

model JobMaterial {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobPostingId String
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  type    MaterialType
  content String?
  version Int          @default(1)
  status  MaterialStatus @default(DRAFT)
}

model FitAnalysis {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobPostingId String     @unique
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  strengths        Json
  gaps             Json
  matchingSkills   Json
  matchingProjects Json

  recommendedAngle  String
  companyType       String
  jobFocus          String
  seniorityDetected String

  confidenceScore Int
}

model ResumeMaster {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rawText    String?
  summary    String?
  experience String?
  projects   String?
  skills     String?
  education  String?
  languages  String?
  links      String?

  experienceInsight ExperienceInsight?
}

model ExperienceInsight {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resumeMasterId String       @unique
  resumeMaster   ResumeMaster @relation(fields: [resumeMasterId], references: [id], onDelete: Cascade)

  insights Json
}

model AutomationRun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type      String
  status    String
  startedAt DateTime?
  endedAt   DateTime?

  logs AutomationLog[]
}

model AutomationLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  runId String
  run   AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  level   String
  message String
  data    Json?
}

model PositioningProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobPostingId String     @unique
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  profile Json
}

enum DiscoveryProvider {
  GREENHOUSE
  LEVER
  ASHBY
}

model CompanySource {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyName  String
  provider     DiscoveryProvider
  providerSlug String
  enabled      Boolean @default(true)
  priority     Int     @default(0)

  @@unique([provider, providerSlug])
}

model RecommendedJob {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title       String
  company     String
  location    String?
  description String?
  applyUrl    String
  source      String
  provider    String
  providerSlug String
  externalId  String?

  matchScore Int     @default(0)
  label      String?
  reasons    Json?
  risks      Json?
  gaps       Json?

  discoveredAt DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  @@unique([provider, externalId])
  @@index([matchScore])
  @@index([provider])
}
