# Database
DATABASE_URL="file:./dev.db"

# LLM — optional. If set, materials are generated with OpenAI; otherwise falls back to deterministic templates.
# Set OPENAI_MODEL to any model you have access to (e.g. gpt-4o, gpt-4.1, gpt-5).
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# App
CAREER_AUTOPILOT_BASE_URL="http://localhost:3000"
